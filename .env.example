# Smart Clothesline IoT System — Environment Variables Template
# ──────────────────────────────────────────────────────────────
# LOCAL DEV : cp .env.local.example .env.local  lalu isi nilainya
# VERCEL    : tambahkan semua variabel di Project Settings → Environment Variables
#             (pilih environment: Preview DAN Production)
#
# ⚠  Setelah ubah env di Vercel, WAJIB redeploy tanpa build cache:
#    Deployments → ⋯ → Redeploy → uncheck "Use existing build cache"
#
# ⚠  Semua NEXT_PUBLIC_FIREBASE_* WAJIB diisi.
#    Jika kosong, server akan melempar error saat startup.

# ── Firebase (wajib — aman untuk browser) ────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── MQTT (wajib — aman untuk browser) ────────────────────────────────────────
NEXT_PUBLIC_MQTT_BROKER_URL=wss://broker.hivemq.com:8884/mqtt
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=
NEXT_PUBLIC_MQTT_TOPIC_SENSOR=smart-clothesline/sensor
NEXT_PUBLIC_MQTT_TOPIC_STATUS=smart-clothesline/status
NEXT_PUBLIC_MQTT_TOPIC_COMMAND=smart-clothesline/command

# ── Telegram (server-only — JANGAN expose ke browser / client) ───────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Secret token yang dikirim Telegram di header X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=
# URL endpoint webhook deployment ini (dipakai saat POST ke /api/telegram/setup)
TELEGRAM_WEBHOOK_URL=https://your-deployment.vercel.app/api/telegram/webhook
# User ID Telegram yang diizinkan sebagai ADMIN (pisah koma)
TELEGRAM_ALLOWED_USER_IDS=
# Group/supergroup ID yang diizinkan (angka negatif, pisah koma)
# Contoh: TELEGRAM_ALLOWED_GROUPS=-1001234567890
TELEGRAM_ALLOWED_GROUPS=
# Set "true" untuk mengizinkan perintah dari grup/supergroup
TELEGRAM_ENABLE_GROUP_MODE=false

# ── Opsional ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# DEBUG_MODE=false
