# Smart Clothesline IoT System — Local Development Template
# ──────────────────────────────────────────────────────────
# CARA PAKAI:
#   cp .env.local.example .env.local
#   Isi semua nilai di bawah, lalu restart dev server (npm run dev)
#
# ⚠  .env.local TIDAK boleh di-commit ke git (sudah ada di .gitignore)
# ⚠  Semua NEXT_PUBLIC_FIREBASE_* WAJIB diisi atau server akan error

# ── Firebase (wajib — aman untuk browser) ────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── MQTT (wajib) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_MQTT_BROKER_URL=wss://broker.hivemq.com:8884/mqtt
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=
NEXT_PUBLIC_MQTT_TOPIC_SENSOR=smart-clothesline/sensor
NEXT_PUBLIC_MQTT_TOPIC_STATUS=smart-clothesline/status
NEXT_PUBLIC_MQTT_TOPIC_COMMAND=smart-clothesline/command

# ── Telegram (server-only — JANGAN expose ke browser) ────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Secret untuk verifikasi request dari Telegram (isi nilai acak)
TELEGRAM_WEBHOOK_SECRET=
# URL webhook deployment ini — dipakai saat setup via /api/telegram/setup
TELEGRAM_WEBHOOK_URL=http://localhost:3000/api/telegram/webhook
# User ID Telegram yang diizinkan (pisah koma): 6393706909
TELEGRAM_ALLOWED_USER_IDS=
# Group ID yang diizinkan (angka negatif, pisah koma): -1001234567890
TELEGRAM_ALLOWED_GROUPS=
# Aktifkan perintah dari grup/supergroup
TELEGRAM_ENABLE_GROUP_MODE=false

# ── Opsional ─────────────────────────────────────────────────────────────────
# DEBUG_MODE=true
# LOG_LEVEL=debug
