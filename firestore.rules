rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isNumber(v) {
      return v is int || v is float;
    }

    function isBoolean(v) {
      return v is bool;
    }

    function isValidTimestampMs(v) {
      return isNumber(v) && v > 0 && v < 4102444800000; // < year 2100
    }

    function isValidSensorPayload(data) {
      return isNumber(data.temperature)
        && data.temperature >= -50
        && data.temperature <= 100
        && isNumber(data.humidity)
        && data.humidity >= 0
        && data.humidity <= 100
        && isNumber(data.light)
        && data.light >= 0
        && data.light <= 100000
        && isBoolean(data.rain)
        && (data.rainVal == null || (isNumber(data.rainVal) && data.rainVal >= 0))
        && (data.rainRaw == null || (isNumber(data.rainRaw) && data.rainRaw >= 0))
        && (data.lightRaw == null || (isNumber(data.lightRaw) && data.lightRaw >= 0))
        && (data.lightThreshold == null || (isNumber(data.lightThreshold) && data.lightThreshold >= 0))
        && (data.status == 'OPEN' || data.status == 'CLOSED' || data.status == 'RESTARTING')
        && (data.deviceId == null || (data.deviceId is string && data.deviceId.size() > 0))
        && (data.mode == null || data.mode == 'AUTO' || data.mode == 'MANUAL')
        && (data.source == null || data.source in ['STATUS_TOPIC', 'SENSOR_FALLBACK', 'UNKNOWN'])
        && (data.receivedAt == null || isValidTimestampMs(data.receivedAt))
        && (data.deviceTimestamp == null || isValidTimestampMs(data.deviceTimestamp))
        && (data.deviceUptimeMs == null || (isNumber(data.deviceUptimeMs) && data.deviceUptimeMs >= 0))
        && (data.createdAt != null || isValidTimestampMs(data.timestamp));
    }

    function isValidTelegramCommand(data) {
      return data.command in ['/open', '/close', '/mode_auto', '/mode_manual', '/restart']
        && data.status in ['pending', 'processing', 'done', 'failed']
        && isNumber(data.userId)
        && isValidTimestampMs(data.createdAt)
        && isValidTimestampMs(data.updatedAt)
        && (data.expiresAt == null || isValidTimestampMs(data.expiresAt))
        && (data.dispatchMode == null || data.dispatchMode in ['bridge-fallback', 'server-direct'])
        && (data.attemptCount == null || isNumber(data.attemptCount));
    }

    match /sensor_data/{docId} {
      allow read: if true;
      allow create: if isValidSensorPayload(request.resource.data);
      allow update: if isValidSensorPayload(request.resource.data);
      allow delete: if false;
    }

    match /events_log/{docId} {
      allow read: if true;
      allow create: if request.resource.data.action is string;
      allow update, delete: if false;
    }

    match /schedules/{docId} {
      allow read: if true;
      allow create, update: if request.resource.data.name is string
        && request.resource.data.enabled is bool
        && (
          (request.resource.data.timeOpen is string && request.resource.data.timeClose is string) ||
          (isNumber(request.resource.data.startHour) && isNumber(request.resource.data.endHour))
        );
      allow delete: if true;
    }

    match /system_settings/{docId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    match /telegram_config/{docId} {
      allow read, write: if false;
    }

    match /telegram_commands/{docId} {
      allow read: if true;
      allow create, update: if isValidTelegramCommand(request.resource.data);
      allow delete: if false;
    }

    match /telegram_audit/{docId} {
      allow read: if true;
      allow create: if request.resource.data.command is string
        && request.resource.data.result is string
        && request.resource.data.detail is string
        && isValidTimestampMs(request.resource.data.timestamp);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
