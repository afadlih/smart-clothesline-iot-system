# Copy this file to `.env.local` and fill ALL values.
# Restart Next.js dev server after editing.
#
# ⚠  ALL variables below are REQUIRED.
#    Missing any NEXT_PUBLIC_FIREBASE_* variable will throw a startup error.
#    Missing TELEGRAM_BOT_TOKEN disables the Telegram integration gracefully.

# ── Telegram (server-only, never exposed to browser) ─────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_IDS=
# Optional: comma-separated negative group IDs to pre-authorize groups
# TELEGRAM_ALLOWED_GROUPS=
# Optional: set to "true" to enable group/supergroup command support
# TELEGRAM_ENABLE_GROUP_MODE=

# ── Firebase (required — safe for browser) ───────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── MQTT (required — safe for browser) ──────────────────────────────────────
NEXT_PUBLIC_MQTT_BROKER_URL=
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=
NEXT_PUBLIC_MQTT_TOPIC_SENSOR=smart-clothesline/sensor
NEXT_PUBLIC_MQTT_TOPIC_STATUS=smart-clothesline/status
NEXT_PUBLIC_MQTT_TOPIC_COMMAND=smart-clothesline/command
