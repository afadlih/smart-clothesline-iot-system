# Smart Clothesline IoT System — Environment Variables Template
# ──────────────────────────────────────────────────────────────
# LOCAL DEV : cp .env.local.example .env.local  lalu isi nilainya
# VERCEL    : tambahkan semua variabel di Project Settings → Environment Variables
#             (pilih environment: Preview DAN Production sesuai kebutuhan)
#
# ⚠  Setelah ubah env di Vercel, WAJIB redeploy tanpa build cache:
#    Deployments → ⋯ → Redeploy → uncheck "Use existing build cache"
#
# ⚠  Semua NEXT_PUBLIC_FIREBASE_* WAJIB diisi.
#    Jika kosong, server akan melempar error saat startup.

# ── Firebase (wajib — aman untuk browser) ────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── MQTT (wajib — aman untuk browser) ────────────────────────────────────────
NEXT_PUBLIC_MQTT_BROKER_URL=wss://broker.hivemq.com:8884/mqtt
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=
NEXT_PUBLIC_MQTT_TOPIC_SENSOR=smart-clothesline/sensor
NEXT_PUBLIC_MQTT_TOPIC_STATUS=smart-clothesline/status
NEXT_PUBLIC_MQTT_TOPIC_COMMAND=smart-clothesline/command

# ── Telegram (server-only — JANGAN expose ke browser / client) ───────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Secret token yang dikirim Telegram di header X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=

# URL dasar deployment STABIL (gunakan domain produksi, bukan URL unik per-deploy)
# Webhook URL akan dibangun otomatis: APP_BASE_URL + /api/telegram/webhook
# ⚠  JANGAN gunakan URL unik Vercel per-deploy (berubah tiap deploy)
# ⚠  Telegram hanya mendukung SATU webhook per bot token
# Contoh production : APP_BASE_URL=https://smart-clothesline-iot-system.vercel.app
# Contoh staging    : APP_BASE_URL=https://stable-staging.vercel.app
APP_BASE_URL=

# Set "true" HANYA untuk production atau staging dengan bot token terpisah.
# Preview/fix branches harus dibiarkan kosong (false).
# Preview branches TIDAK boleh mengaktifkan webhook — akan menimpa webhook produksi!
# Production  : TELEGRAM_WEBHOOK_ENABLED=true
# Preview/fix : TELEGRAM_WEBHOOK_ENABLED=false (atau tidak diset)
TELEGRAM_WEBHOOK_ENABLED=false

# User ID Telegram yang diizinkan sebagai ADMIN (pisah koma)
TELEGRAM_ALLOWED_USER_IDS=
# Group/supergroup ID yang diizinkan (angka negatif, pisah koma)
TELEGRAM_ALLOWED_GROUPS=
# Set "true" untuk mengizinkan perintah dari grup/supergroup
TELEGRAM_ENABLE_GROUP_MODE=false

# ── Opsional ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# DEBUG_MODE=false
