# Smart Clothesline IoT System - Environment Template
# Copy to .env.local for local development.
# On Vercel, configure values per environment (Preview/Production).

# Firebase (public by design for client app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# MQTT (public in browser if using NEXT_PUBLIC_*)
# WARNING: Browser MQTT credentials are visible to users.
NEXT_PUBLIC_MQTT_BROKER_URL=wss://broker.example.com:8884/mqtt
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=
NEXT_PUBLIC_MQTT_TOPIC_SENSOR=smart-clothesline/sensor
NEXT_PUBLIC_MQTT_TOPIC_STATUS=smart-clothesline/status
NEXT_PUBLIC_MQTT_TOPIC_COMMAND=smart-clothesline/command

# Telegram (server-only secrets)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_GROUPS=
TELEGRAM_ENABLE_GROUP_MODE=false

# Deployment Config
# APP_BASE_URL is required for Telegram webhook registration in production/staging.
APP_BASE_URL=
TELEGRAM_DROP_PENDING_UPDATES_ON_WEBHOOK_SETUP=true

# Operational Config (matching firmware)
# light normalized 0..10000, higher is brighter.
# lightRaw is ADC debug (Wokwi 4095=dark, 0=bright).
# lightThreshold defaults to 3000.

# Optional runtime controls
DEBUG_MODE=false
LOG_LEVEL=info
