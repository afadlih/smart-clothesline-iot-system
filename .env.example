# Smart Clothesline IoT System - Environment Template
# Copy to .env.local for local development.
# On Vercel, configure values per environment (Preview/Production).

# Firebase (public by design for client app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# MQTT (public in browser if using NEXT_PUBLIC_*)
# WARNING:
# - Do not put privileged MQTT credentials in NEXT_PUBLIC variables.
# - Browser MQTT credentials are visible to users.
# - Use limited ACL credentials only for demo/preview browser access.
NEXT_PUBLIC_MQTT_BROKER_URL=wss://broker.example.com:8884/mqtt
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=
NEXT_PUBLIC_MQTT_TOPIC_SENSOR=smart-clothesline/sensor
NEXT_PUBLIC_MQTT_TOPIC_STATUS=smart-clothesline/status
NEXT_PUBLIC_MQTT_TOPIC_COMMAND=smart-clothesline/command

# Server MQTT (server-side only, for Telegram command publisher)
# These credentials must be able to publish to the command topic.
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_COMMAND=smart-clothesline/command
MQTT_TARGET_DEVICE_ID=
INTERNAL_COMMAND_SECRET=

# Telegram (server-only secrets)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_GROUPS=
TELEGRAM_ENABLE_GROUP_MODE=false
# TELEGRAM_RUNTIME_MODE:
# - Use "webhook" for staging/production (requires stable APP_BASE_URL).
# - Use "polling" ONLY for local dev bots.
# - Never use a shared staging/production bot for local polling as it will steal updates.
TELEGRAM_RUNTIME_MODE=
TELEGRAM_LOCAL_POLLING_ENABLED=false
TELEGRAM_DROP_PENDING_UPDATES_ON_POLLING_START=true
TELEGRAM_IGNORE_UPDATES_BEFORE_START=true
TELEGRAM_MAX_UPDATES_PER_POLL=10
TELEGRAM_COMMAND_TTL_MS=120000
TELEGRAM_COMMAND_MAX_AGE_MS=300000

# Stable base URL for webhook registration
# Do not use unique per-deployment preview URLs.
APP_BASE_URL=
TELEGRAM_WEBHOOK_ENABLED=false

# Optional runtime controls
DEBUG_MODE=false
LOG_LEVEL=info
